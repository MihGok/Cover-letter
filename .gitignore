# Игнорируем все файлы по умолчанию
*
!*/
!.gitignore

# Разрешаем только нужные расширения файлов
!*.js
!*.jsx
!*.html
!*.py
!*.css

# Явно игнорируем нежелательные форматы
*.cmd
*.json
*.ps1

# Игнорируем папки с артефактами
node_modules/
__pycache__/
.venv/
venv/
env/
dist/
build/
.pytest_cache/
.egg-info/

# IDE и системные файлы
.vscode/
.idea/
.DS_Store
Thumbs.db
*.pyc
*.pyo
*.pyd
.env
.env.local

# Логи и временные файлы
*.log
*.tmp
*.swp
*.swo
*~
